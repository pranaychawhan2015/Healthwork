{
    "name": "test-network-${ORG}",
    "version": "1.0.0",
    "client": {
        "organization": "${ORG}",
        "connection": {
            "timeout": {
                "peer": {
                    "endorser": "300"
                }
            }
        }
    },
    "organizations": {
        "${ORG}": {
            "mspid": "${ORG}",
            "peers": [
                "peer0.${ORG}.example.com",
                "peer1.${ORG}.example.com",
                "peer2.${ORG}.example.com",
                "peer3.${ORG}.example.com"
            ],
            "certificateAuthorities": [
                "ca.${ORG}.example.com"
            ]
        }
    },
    "peers": {
        "peer0.${ORG}.example.com": {
            "url": "grpcs://localhost:${P0PORT}",
            "tlsCACerts": {
                "pem": "${PEERPEM}"
            },
            "grpcOptions": {
                "ssl-target-name-override": "peer0.${ORG}.example.com",
                "hostnameOverride": "peer0.${ORG}.example.com"
            },
            "signCert" : {
                "pem": "${CERT0}"
            },
            "privateKey":{
                "pem":"${KEY0}"
            }
        },
        "peer1.${ORG}.example.com": {
            "url": "grpcs://localhost:${P1PORT}",
            "tlsCACerts": {
                "pem": "${PEERPEM}"
            },
            "grpcOptions": {
                "ssl-target-name-override": "peer1.${ORG}.example.com",
                "hostnameOverride": "peer1.${ORG}.example.com"
            },
            "signCert" : {
                "pem": "${CERT1}"
            },
            "privateKey":{
                "pem":"${KEY1}"
            }
        },
        "peer2.${ORG}.example.com": {
            "url": "grpcs://localhost:${P2PORT}",
            "tlsCACerts": {
                "pem": "${PEERPEM}"
            },
            "grpcOptions": {
                "ssl-target-name-override": "peer2.${ORG}.example.com",
                "hostnameOverride": "peer2.${ORG}.example.com"
            },
            "signCert" : {
                "pem": "${CERT2}"
            },
            "privateKey":{
                "pem":"${KEY2}"
            }
        },
        "peer3.${ORG}.example.com": {
            "url": "grpcs://localhost:${P3PORT}",
            "tlsCACerts": {
                "pem": "${PEERPEM}"
            },
            "grpcOptions": {
                "ssl-target-name-override": "peer3.${ORG}.example.com",
                "hostnameOverride": "peer3.${ORG}.example.com"
            },
            "signCert" : {
                "pem": "${CERT3}"
            },
            "privateKey":{
                "pem":"${KEY3}"
            }
        }
    },
    "certificateAuthorities": {
        "ca.org${ORG}.example.com": {
            "url": "https://localhost:${CAPORT}",
            "caName": "${CAORG}",
            "tlsCACerts": {
                "pem": ["${CAPEM}"]
            },
            "httpOptions": {
                "verify": false
            }
        }
    }
}
